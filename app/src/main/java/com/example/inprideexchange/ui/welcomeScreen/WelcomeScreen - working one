package com.example.inprideexchange.ui.welcomeScreen

import android.widget.Toast
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.pager.HorizontalPager
import androidx.compose.foundation.pager.rememberPagerState
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Modifier
import androidx.compose.ui.platform.LocalContext
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.tooling.preview.Preview
import androidx.compose.ui.unit.dp
import androidx.constraintlayout.compose.ConstraintLayout
import androidx.constraintlayout.compose.Dimension
import com.example.inprideexchange.R
import com.example.inprideexchange.ui.components.buttons.GoogleSmartButton
import com.example.inprideexchange.ui.designSystem.dimens.AppDimens

@Composable
fun WelcomeScreen(
    onPhoneClick: () -> Unit,
    onGoogleClick: () -> Unit,
    isLoading: Boolean = false
) {

    val context = LocalContext.current

    val pages = remember {
        listOf(

            OnboardingItem(
                image = R.drawable.market,
                title = "Stay Ahead of the Market",
                subtitle = "Track news, trends, and deep technical breakdowns before others react"
            ),
            OnboardingItem(
                image = R.drawable.change_2,
                title = "Trade Smarter, Not Harder",
                subtitle = "Get accurate forex signals, real-time market insights, and expert analysis"
            ),
            OnboardingItem(
                image = R.drawable.dollar,
                title = "Smart Pools. Real Returns.",
                subtitle = "Invest early, secure your slot, and grow with structured opportunities"
            ),

            )
    }

    val pagerState = rememberPagerState(pageCount = { pages.size })

    Surface(
        modifier = Modifier.fillMaxSize(),
        color = MaterialTheme.colorScheme.background
    ) {

        ConstraintLayout(
            modifier = Modifier
                .fillMaxSize()
                .padding(WindowInsets.safeDrawing.asPaddingValues())
                .padding(AppDimens.PaddingMedium),
        ) {

            val (
                logoRef,
                pagerRef,
                termsTextRef,
                buttonRef,
                skipRef,
                indicatorRef,
            ) = createRefs()


            Logo(
                modifier = Modifier.constrainAs(logoRef) {
                    top.linkTo(parent.top)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                    width = Dimension.fillToConstraints
                },
            )




            HorizontalPager(
                state = pagerState,
                modifier = Modifier.constrainAs(pagerRef) {
                    top.linkTo(logoRef.bottom, margin = 50.dp)
                    bottom.linkTo(parent.bottom, margin = 50.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                    width = Dimension.fillToConstraints
                    verticalBias = 0.3f
                }
            ) { page ->
                key(page) {
                    OnboardingPage(item = pages[page])
                }
            }




            Box(
                modifier = Modifier
                    .wrapContentSize()
                    .constrainAs(indicatorRef) {
                        bottom.linkTo(skipRef.top)
                        start.linkTo(parent.start)
                        end.linkTo(parent.end)
                    }) {

                PagerIndicator(
                    pageCount = pages.size,
                    currentPage = pagerState.currentPage,

                    )
            }

            Row(
                modifier = Modifier.constrainAs(skipRef) {
                    bottom.linkTo(buttonRef.top, margin = 16.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                },
                horizontalArrangement = Arrangement.Center
            ) {
                TextButton(
                    onClick = onPhoneClick
                ) {
                    Text(
                        //  text = if (isLastPage) "Done" else "Skip",
                        text = "Skip",
                        style = MaterialTheme.typography.bodyMedium.copy(
                            fontWeight = FontWeight.Medium
                        )
                    )
                }
            }





            GoogleSmartButton(
                text = "Continue with Google",
                isEnabled = !isLoading,
                isLoading = isLoading,
                onClick = onGoogleClick,
                modifier = Modifier.constrainAs(buttonRef) {
                    bottom.linkTo(termsTextRef.top, margin = 20.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                    width = Dimension.fillToConstraints
                }
            )

            Box(modifier = Modifier
                .wrapContentSize()
                .constrainAs(termsTextRef) {
                    bottom.linkTo(parent.bottom, margin = 20.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                }) {

                TermsText(
                    onTermsClick = {
                        Toast.makeText(context, "onTermsClick", Toast.LENGTH_SHORT).show()
                    },
                    onPrivacyClick = {
                        Toast.makeText(context, "onPrivacyClick", Toast.LENGTH_SHORT).show()
                    },

                    )
            }


        }
    }

}


