@Composable
fun WelcomeScreen(
    onPhoneClick: () -> Unit,
    onGoogleClick: () -> Unit,
    isLoading: Boolean = false
) {

    val context = LocalContext.current

    val pages = remember {
        listOf(
            OnboardingItem(
                image = R.drawable.market,
                title = "Stay Ahead of the Market",
                subtitle = "Track news, trends, and deep technical breakdowns before others react"
            ),
            OnboardingItem(
                image = R.drawable.change,
                title = "Trade Smarter, Not Harder",
                subtitle = "Get accurate forex signals, real-time market insights, and expert analysis"
            ),
        )
    }

    val pagerState = rememberPagerState(pageCount = { pages.size })
    val isLastPage = pagerState.currentPage == pages.lastIndex

    Surface(
        modifier = Modifier.fillMaxSize(),
        color = MaterialTheme.colorScheme.background
    ) {

        ConstraintLayout(
            modifier = Modifier
                .fillMaxSize()
              //  .padding(WindowInsets.safeDrawing.asPaddingValues())
                .padding(AppDimens.PaddingMedium),
        ) {

            val (
                skipRef,
                logoRef,
                pagerRef,
                indicatorRef,
                buttonRef,
                termsRef
            ) = createRefs()

            // 🔹 Skip (Top Right)
            TextButton(
                onClick = onPhoneClick,
                modifier = Modifier.constrainAs(skipRef) {
                    top.linkTo(parent.top)
                    end.linkTo(parent.end)
                }
            ) {
                Text(
                    text = if (isLastPage) "Done" else "Skip",
                    style = MaterialTheme.typography.labelLarge.copy(
                        fontWeight = FontWeight.Medium
                    )
                )
            }

            // 🔹 Logo (Below Skip)
            androidx.compose.foundation.layout.Row(
                verticalAlignment = Alignment.CenterVertically,
                modifier = Modifier.constrainAs(logoRef) {
                    top.linkTo(skipRef.bottom, margin = 8.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                }
            ) {
                androidx.compose.foundation.layout.Box(
                    modifier = Modifier
                        .clip(RoundedCornerShape(8.dp))
                        .background(MaterialTheme.colorScheme.primary)
                        .padding(8.dp),
                    contentAlignment = Alignment.Center
                ) {
                    Text(
                        text = "In",
                        style = MaterialTheme.typography.bodyMedium.copy(
                            fontWeight = FontWeight.Bold
                        ),
                        color = MaterialTheme.colorScheme.surface
                    )
                }

                androidx.compose.foundation.layout.Spacer(modifier = Modifier.padding(4.dp))

                Text(
                    text = "Store",
                    style = MaterialTheme.typography.titleMedium.copy(
                        fontWeight = FontWeight.SemiBold
                    )
                )
            }

            // 🔥 Pager (CENTERED PROPERLY)
            HorizontalPager(
                state = pagerState,
                modifier = Modifier.constrainAs(pagerRef) {
                    top.linkTo(logoRef.bottom)
                    bottom.linkTo(indicatorRef.top)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                    height = Dimension.fillToConstraints
                    width = Dimension.fillToConstraints
                }
            ) { page ->
                key(page) {
                    OnboardingPage(item = pages[page])
                }
            }

            // 🔹 Indicator (Above Button)
            PagerIndicator(
                pageCount = pages.size,
                currentPage = pagerState.currentPage,
                modifier = Modifier.constrainAs(indicatorRef) {
                    bottom.linkTo(buttonRef.top, margin = 16.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                }
            )

            // 🔹 Button (Above Terms)
            GoogleSmartButton(
                text = "Continue with Google",
                isEnabled = !isLoading,
                isLoading = isLoading,
                onClick = onGoogleClick,
                modifier = Modifier.constrainAs(buttonRef) {
                    bottom.linkTo(termsRef.top, margin = 16.dp)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                    width = Dimension.fillToConstraints
                }
            )

            // 🔹 Terms (Bottom)
            TermsText(
                onTermsClick = {
                    Toast.makeText(context, "onTermsClick", Toast.LENGTH_SHORT).show()
                },
                onPrivacyClick = {
                    Toast.makeText(context, "onPrivacyClick", Toast.LENGTH_SHORT).show()
                },
                modifier = Modifier.constrainAs(termsRef) {
                    bottom.linkTo(parent.bottom)
                    start.linkTo(parent.start)
                    end.linkTo(parent.end)
                }
            )
        }
    }
}

