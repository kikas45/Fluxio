@Composable
fun GoogleSmartButton(
    text: String = "Continue with Google",
    isEnabled: Boolean,
    isLoading: Boolean,
    onClick: () -> Unit,
    modifier: Modifier = Modifier
) {

    val bgEnabled = MaterialTheme.colorScheme.surface
    val bgDisabled = MaterialTheme.colorScheme.surfaceVariant.copy(alpha = 0.7f)

    val contentEnabled = MaterialTheme.colorScheme.onSurface
    val contentDisabled = MaterialTheme.colorScheme.onSurfaceVariant

    val effectiveEnabled = isEnabled && !isLoading

    val backgroundColor by animateColorAsState(
        targetValue = if (effectiveEnabled) bgEnabled else bgDisabled,
        label = "googleBtnBg"
    )

    val contentColor by animateColorAsState(
        targetValue = if (effectiveEnabled) contentEnabled else contentDisabled,
        label = "googleBtnContent"
    )

    val borderColor by animateColorAsState(
        targetValue = if (effectiveEnabled) contentEnabled.copy(alpha = 0.2f)
        else bgDisabled,
        label = "googleBtnBorder"
    )

    val interactionSource = remember { MutableInteractionSource() }
    val shape = AppShapes.Rounded12

    Box(
        modifier = modifier
            .fillMaxWidth()
            .clip(shape)
            .background(backgroundColor)
            .border(1.dp, borderColor, shape)
            .clickable(
                enabled = effectiveEnabled,
                interactionSource = interactionSource,
                indication = ripple(
                    bounded = true,
                    color = contentColor.copy(alpha = 0.2f)
                ),
                onClick = onClick
            )
            .padding(horizontal = 16.dp, vertical = 12.dp)
    ) {

        // 🔹 LEFT: Google Icon (fixed position)
        Image(
            painter = painterResource(id = R.drawable.google_icon),
            contentDescription = "Google",
            modifier = Modifier
                .align(Alignment.CenterStart)
                .size(18.dp)
        )

        // 🔹 CENTER: Text (always centered regardless of icon/loader)
        Text(
            text = text,
            color = contentColor,
            modifier = Modifier.align(Alignment.Center),
            style = MaterialTheme.typography.bodyMedium
        )

        // 🔹 RIGHT: Loader (fixed position)
        if (isLoading) {
            CircularProgressIndicator(
                modifier = Modifier
                    .align(Alignment.CenterEnd)
                    .size(18.dp),
                strokeWidth = 2.dp,
                color = contentColor
            )
        }
    }
}